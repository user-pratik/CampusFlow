# Groq LLM Configuration — comma-separated keys for rolling rotation
GROQ_API_KEY="your_groq_api_key_here"
GROQ_MODEL=llama-3.3-70b-versatile

# VTOP Portal Credentials
VTOP_USERNAME=223BAI112
VTOP_PASSWORD=your_vtop_password
VTOP_POLL_INTERVAL=1800

# ngrok — required for WhatsApp webhooks (auto-started on backend boot)
# Get your free authtoken from https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=your_ngrok_authtoken

# WhatsApp Bridge — Evolution API (auto-configured on startup)
# Docker container runs on port 8080 — started automatically if docker-compose is available
EVOLUTION_API_KEY=campusflow-secret
EVOLUTION_BASE_URL=http://localhost:8080

# Moodle LMS — for fetching assignment deadlines
# Generate token at: https://lms.vit.ac.in/user/managetoken.php
# OR use login endpoint: https://lms.vit.ac.in/login/token.php?username=X&password=Y&service=moodle_mobile_app
# Leave empty to disable Moodle integration.
MOODLE_URL=https://lms.vit.ac.in
MOODLE_TOKEN=
